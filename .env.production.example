PORT=8080

MYSQL_DATABASE=spring_boot_study
MYSQL_USER=spring
MYSQL_PASSWORD=change_me_database_password
MYSQL_ROOT_PASSWORD=change_me_root_password

SPRING_JPA_HIBERNATE_DDL_AUTO=update

JWT_SECRET=replace_with_a_long_random_secret_at_least_32_bytes
JWT_ACCESS_TOKEN_VALIDITY_IN_SECONDS=3600

KAKAO_CLIENT_ID=your_kakao_rest_api_key
KAKAO_CLIENT_SECRET=your_kakao_client_secret
KAKAO_REDIRECT_URI=http://your-ec2-public-ip:8080/oauth/kakao/callback
